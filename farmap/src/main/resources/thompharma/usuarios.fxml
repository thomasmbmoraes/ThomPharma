<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.UsuariosController"
            stylesheets="@thompharma.css">

    <top>
        <VBox styleClass="cabecalho">
            <Label text="Cadastro de Usuários" styleClass="cabecalho-titulo"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Usuários:"/>
                <TableView fx:id="tabelaUsuarios" prefHeight="420">
                    <columns>
                        <TableColumn fx:id="colUsuario" text="Usuário" prefWidth="130"/>
                        <TableColumn fx:id="colNome"    text="Nome"    prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" prefWidth="320">
                <Label text="Usuário:"/>
                <TextField fx:id="campoUsuario"/>

                <Label text="Nome Completo:"/>
                <TextField fx:id="campoNome"/>

                <Label text="Senha:"/>
                <PasswordField fx:id="campoSenha"/>

                <CheckBox fx:id="checkAdmin" text="Administrador"/>
                <CheckBox fx:id="checkAtivo" text="Ativo" selected="true"/>

                <Label fx:id="mensagem" wrapText="true"/>

                <HBox spacing="10">
                    <Button text="Novo"    onAction="#novo"    styleClass="btn-novo"/>
                    <Button text="Salvar"  onAction="#salvar"  styleClass="btn-salvar"/>
                    <Button text="Excluir" onAction="#excluir" styleClass="btn-excluir"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="Fechar" onAction="#fechar" styleClass="btn-fechar"/>
        </HBox>
    </bottom>

</BorderPane>
