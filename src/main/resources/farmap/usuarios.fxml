<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="farmap.telas.UsuariosController">

    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="Cadastro de Usuários"
                   style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Lista de usuários -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Usuários:"/>
                <TableView fx:id="tabelaUsuarios" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="colUsuario" text="Usuário" prefWidth="120"/>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Formulário -->
            <VBox spacing="10" prefWidth="300">
                <Label text="Usuário:"/>
                <TextField fx:id="campoUsuario"/>
                <Label text="Nome Completo:"/>
                <TextField fx:id="campoNome"/>
                <Label text="Senha:"/>
                <PasswordField fx:id="campoSenha"/>
                <CheckBox fx:id="checkAdmin" text="Administrador"/>
                <CheckBox fx:id="checkAtivo" text="Ativo" selected="true"/>
                <Label fx:id="mensagem" style="-fx-text-fill: red;"/>
                <HBox spacing="10">
                    <Button text="Novo" onAction="#novo"/>
                    <Button text="Salvar" onAction="#salvar"/>
                    <Button text="Excluir" onAction="#excluir"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Button text="Fechar" onAction="#fechar"/>
        </HBox>
    </bottom>

</BorderPane>