<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="farmap.telas.ClientesController">

    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="Cadastro de Clientes"
                   style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- lista de clientes -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Clientes:"/>
                <TextField fx:id="campoFiltro" promptText="Filtrar..."/>
		<TableView fx:id="tabelaClientes" prefHeight="500" prefWidth="280">
		    <columns>
		        <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
		        <TableColumn fx:id="colTelefone" text="Tel/CRM" prefWidth="80"/>
		        <TableColumn fx:id="colEndereco" text="Endereço" prefWidth="150"/>
		    </columns>
		</TableView>
            </VBox>

            <!-- formulario -->
            <ScrollPane fitToWidth="true" prefWidth="450">
                <VBox spacing="10">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="5"/>
                    </padding>

                    <Label text="Nome:"/>
                    <TextField fx:id="campoNome"/>

                    <Label text="CPF:"/>
                    <TextField fx:id="campoCpf"/>

                    <HBox spacing="20">
                        <VBox spacing="5">
                            <Label text="Telefone:"/>
                            <TextField fx:id="campoTelefone"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="2º Telefone:"/>
                            <TextField fx:id="campoTelefone2"/>
                        </VBox>
                    </HBox>

                    <Label text="Email:"/>
                    <TextField fx:id="campoEmail"/>

                    <HBox spacing="20">
                        <VBox spacing="5">
                            <Label text="Nascimento:"/>
                            <TextField fx:id="campoNascimento" promptText="dd/mm/aaaa"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Desconto %:"/>
                            <TextField fx:id="campoDesconto" prefWidth="80"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="20">
                        <VBox spacing="5">
                            <Label text="CEP:"/>
                            <TextField fx:id="campoCep" prefWidth="100"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="UF:"/>
                            <TextField fx:id="campoUf" prefWidth="50"/>
                        </VBox>
                    </HBox>

                    <Label text="Endereço:"/>
                    <TextField fx:id="campoEndereco"/>

                    <HBox spacing="20">
                        <VBox spacing="5">
                            <Label text="Bairro:"/>
                            <TextField fx:id="campoBairro"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Cidade:"/>
                            <TextField fx:id="campoCidade"/>
                        </VBox>
                    </HBox>

                    <CheckBox fx:id="checkMedico" text="É Médico/Dentista/Veterinário"
                              onAction="#toggleMedico"/>

                    <VBox fx:id="painelMedico" spacing="10" visible="false" managed="false">
                        <Label text="CRM/CRO/CRV:"/>
                        <TextField fx:id="campoCrm"/>
                        <Label text="Especialidade:"/>
                        <ComboBox fx:id="comboEspecialidade" prefWidth="300"/>
                    </VBox>

                    <Label text="Observações:"/>
                    <TextArea fx:id="campoObservacoes" prefHeight="80"/>

                    <Label fx:id="mensagem" style="-fx-text-fill: red;"/>

                    <HBox spacing="10">
                        <Button text="Novo" onAction="#novo"/>
                        <Button text="Salvar" onAction="#salvar"/>
                        <Button text="Excluir" onAction="#excluir"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Button text="Fechar" onAction="#fechar"/>
        </HBox>
    </bottom>

</BorderPane>