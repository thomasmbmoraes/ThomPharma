<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="farmap.telas.LoginController">

    <VBox alignment="CENTER" spacing="10" maxWidth="400" maxHeight="300"
          style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 8;">

        <Label text="Farmap - Sistema de Farmacia de Manipulacao"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Label text="Usuário:"/>
        <TextField fx:id="campoUsuario"/>
        <Label text="Senha:"/>
        <PasswordField fx:id="campoSenha"/>
        <Button text="Entrar" onAction="#fazerLogin" maxWidth="Infinity"/>
        <Label fx:id="mensagemErro" style="-fx-text-fill: red;"/>

    </VBox>

</StackPane>