<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.PrescritoresController">

    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="Cadastro de Prescritores"
                   style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- lista de prescritores com filtros -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Prescritores:"/>
                <TextField fx:id="campoFiltro" promptText="Filtrar por nome..."/>
                <ComboBox fx:id="comboFiltroTipo" prefWidth="200" promptText="Filtrar por tipo..."/>
                <TableView fx:id="tabelaPrescritores" prefHeight="500" prefWidth="320">
                    <columns>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="160"/>
                        <TableColumn fx:id="colTipo" text="Tipo" prefWidth="80"/>
                        <TableColumn fx:id="colRegistro" text="Registro" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- formulario -->
            <ScrollPane fitToWidth="true" prefWidth="400">
                <VBox spacing="10">
                    <padding>
                        <Insets top="5" right="10" bottom="5" left="5"/>
                    </padding>

                    <Label text="Nome:"/>
                    <TextField fx:id="campoNome"/>

                    <Label text="Tipo de Registro:"/>
                    <ComboBox fx:id="comboTipoRegistro" prefWidth="300"/>

                    <Label text="Número do Registro:"/>
                    <TextField fx:id="campoNumeroRegistro" promptText="Ex: 12345"/>

                    <Label text="Telefone:"/>
                    <TextField fx:id="campoTelefone"/>

                    <Label text="Email:"/>
                    <TextField fx:id="campoEmail"/>

                    <Label text="Observações:"/>
                    <TextArea fx:id="campoObservacoes" prefHeight="100"/>

                    <Label fx:id="mensagem" style="-fx-text-fill: red;"/>

                    <HBox spacing="10">
                        <Button text="Novo" onAction="#novo"/>
                        <Button text="Salvar" onAction="#salvar"/>
                        <Button text="Excluir" onAction="#excluir"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Button text="Fechar" onAction="#fechar"/>
        </HBox>
    </bottom>

</BorderPane>
