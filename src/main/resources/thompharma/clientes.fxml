<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.ClientesController"
            stylesheets="@thompharma.css">

    <top>
        <VBox styleClass="cabecalho">
            <Label text="Cadastro de Clientes" styleClass="cabecalho-titulo"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Clientes:"/>
                <TextField fx:id="campoFiltro" promptText="Filtrar por nome..."/>
                <TableView fx:id="tabelaClientes" prefHeight="500" prefWidth="320">
                    <columns>
                        <TableColumn fx:id="colNome"     text="Nome"     prefWidth="160"/>
                        <TableColumn fx:id="colCpf"      text="CPF"      prefWidth="110"/>
                        <TableColumn fx:id="colTelefone" text="Telefone" prefWidth="110"/>
                    </columns>
                </TableView>
            </VBox>

            <ScrollPane fx:id="scrollFormulario" fitToWidth="true" prefWidth="450">
                <VBox spacing="10">
                    <padding><Insets top="5" right="10" bottom="5" left="5"/></padding>

                    <Label text="Nome:"/>
                    <TextField fx:id="campoNome"/>

                    <Label text="CPF:"/>
                    <TextField fx:id="campoCpf"/>

                    <HBox spacing="16">
                        <VBox spacing="5">
                            <Label text="Telefone:"/>
                            <TextField fx:id="campoTelefone"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="2º Telefone:"/>
                            <TextField fx:id="campoTelefone2"/>
                        </VBox>
                    </HBox>

                    <Label text="Email:"/>
                    <TextField fx:id="campoEmail"/>

                    <HBox spacing="16">
                        <VBox spacing="5">
                            <Label text="Nascimento:"/>
                            <TextField fx:id="campoNascimento" promptText="dd/mm/aaaa"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Desconto %:"/>
                            <TextField fx:id="campoDesconto" prefWidth="80"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <VBox spacing="5">
                            <Label text="CEP:"/>
                            <TextField fx:id="campoCep" prefWidth="100"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="UF:"/>
                            <TextField fx:id="campoUf" prefWidth="50"/>
                        </VBox>
                    </HBox>

                    <Label text="Endereço:"/>
                    <TextField fx:id="campoEndereco"/>

                    <HBox spacing="16">
                        <VBox spacing="5">
                            <Label text="Bairro:"/>
                            <TextField fx:id="campoBairro"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Cidade:"/>
                            <TextField fx:id="campoCidade"/>
                        </VBox>
                    </HBox>

                    <Label text="Observações:"/>
                    <TextArea fx:id="campoObservacoes" prefHeight="80"/>

                    <Label fx:id="mensagem" wrapText="true"/>

                    <HBox spacing="10">
                        <Button text="Novo"   onAction="#novo"   styleClass="btn-novo"/>
                        <Button text="Salvar" onAction="#salvar" styleClass="btn-salvar"/>
                        <Button text="Excluir" onAction="#excluir" styleClass="btn-excluir"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="Fechar" onAction="#fechar" styleClass="btn-fechar"/>
        </HBox>
    </bottom>

</BorderPane>
