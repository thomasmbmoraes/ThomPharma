<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.CalculadoraController">

    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="Calculadora Farmacêutica"
                   style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- ======================================================
                 ABA 1: FLORAL
                 ml por floral = volume x 0,002
                 gotas por floral = ml x 30
                 ====================================================== -->
            <Tab text="Floral">
                <VBox spacing="15" prefWidth="600">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label text="Cálculo para Fórmulas Florais"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <Label text="Referência: 30 ml → 0,06 ml/floral (2 gotas) | 100 ml → 0,2 ml/floral (6 gotas)"
                           style="-fx-text-fill: #555;"/>

                    <GridPane hgap="10" vgap="8">
                        <Label text="Volume total (ml):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="floralVolume" prefWidth="120"
                                   promptText="Ex: 30"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Número de florais:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="floralNumFlorais" prefWidth="120"
                                   promptText="Ex: 5"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Calcular" onAction="#calcularFloral"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button text="Limpar" onAction="#limparFloral"/>
                    </HBox>

                    <TextArea fx:id="floralResultado"
                              prefHeight="250"
                              editable="false"
                              style="-fx-font-family: monospace;"/>
                </VBox>
            </Tab>

            <!-- ======================================================
                 ABA 2: HOMEOPATIA LIQUIDA
                 gotas por med = (volume x 30) / num_meds
                 ====================================================== -->
            <Tab text="Homeopatia Líquida">
                <VBox spacing="15" prefWidth="600">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label text="Cálculo para Homeopatia Líquida (CH / DH)"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <Label text="Distribui as gotas igualmente entre os medicamentos"
                           style="-fx-text-fill: #555;"/>

                    <GridPane hgap="10" vgap="8">
                        <Label text="Volume total (ml):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="homoLiqVolume" prefWidth="120"
                                   promptText="Ex: 30"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Número de medicamentos:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="homoLiqNumMeds" prefWidth="120"
                                   promptText="Ex: 3"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Escala:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="homoLiqEscala" prefWidth="140"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Calcular" onAction="#calcularHomoLiq"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button text="Limpar" onAction="#limparHomoLiq"/>
                    </HBox>

                    <TextArea fx:id="homoLiqResultado"
                              prefHeight="220"
                              editable="false"
                              style="-fx-font-family: monospace;"/>
                </VBox>
            </Tab>

            <!-- ======================================================
                 ABA 3: HOMEOPATIA GLOBULOS
                 ml total = volume x 0,03
                 distribui em gotas entre os medicamentos
                 ====================================================== -->
            <Tab text="Homeopatia Glóbulos">
                <VBox spacing="15" prefWidth="600">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label text="Cálculo para Homeopatia em Glóbulos"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <Label text="Referência: 20 ml → 0,6 ml de glóbulos | 30 ml → 0,9 ml de glóbulos (3%)"
                           style="-fx-text-fill: #555;"/>

                    <GridPane hgap="10" vgap="8">
                        <Label text="Volume total (ml):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="homoGlobVolume" prefWidth="120"
                                   promptText="Ex: 20"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Número de medicamentos:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="homoGlobNumMeds" prefWidth="120"
                                   promptText="Ex: 3"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Calcular" onAction="#calcularHomoGlob"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button text="Limpar" onAction="#limparHomoGlob"/>
                    </HBox>

                    <TextArea fx:id="homoGlobResultado"
                              prefHeight="260"
                              editable="false"
                              style="-fx-font-family: monospace;"/>
                </VBox>
            </Tab>

            <!-- ======================================================
                 ABA 4: HOMEOPATIA DOSE UNICA
                 total fixo = 0,6ml dividido entre os medicamentos
                 ====================================================== -->
            <Tab text="Dose Única">
                <VBox spacing="15" prefWidth="600">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <Label text="Cálculo para Homeopatia — Dose Única"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <Label text="Volume total fixo: 0,60 ml. Distribuído entre os medicamentos em gotas inteiras."
                           style="-fx-text-fill: #555;"/>

                    <GridPane hgap="10" vgap="8">
                        <Label text="Número de medicamentos:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="homoDoseNumMeds" prefWidth="120"
                                   promptText="Ex: 3"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Calcular" onAction="#calcularHomoDose"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button text="Limpar" onAction="#limparHomoDose"/>
                    </HBox>

                    <TextArea fx:id="homoDoseResultado"
                              prefHeight="260"
                              editable="false"
                              style="-fx-font-family: monospace;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Button text="Fechar" onAction="#fechar"/>
        </HBox>
    </bottom>

</BorderPane>
