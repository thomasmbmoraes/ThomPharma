<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.ReceitasController"
            stylesheets="@thompharma.css">

    <top>
        <VBox styleClass="cabecalho">
            <Label text="Cadastro de Receitas" styleClass="cabecalho-titulo"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>

            <HBox spacing="20">

                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Receitas:"/>
                    <TextField fx:id="campoFiltro" promptText="Buscar por nome ou ingrediente..."/>
                    <ComboBox fx:id="comboFiltroTipo" prefWidth="250" promptText="Filtrar por tipo..."/>
                    <TableView fx:id="tabelaReceitas" prefHeight="260">
                        <columns>
                            <TableColumn fx:id="colNome"         text="Nome"         prefWidth="200"/>
                            <TableColumn fx:id="colTipo"         text="Tipo"         prefWidth="90"/>
                            <TableColumn fx:id="colNomeFantasia" text="Nome Fantasia" prefWidth="160"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button text="Nova"   onAction="#novo"    styleClass="btn-novo"/>
                        <Button text="Salvar" onAction="#salvar"  styleClass="btn-salvar"/>
                        <Button text="Excluir" onAction="#excluir" styleClass="btn-excluir"/>
                    </HBox>
                </VBox>

                <VBox spacing="8" prefWidth="380">
                    <Label text="Nome da Receita:"/>
                    <TextField fx:id="campoNome"/>

                    <Label text="Nome Fantasia (opcional):"/>
                    <TextField fx:id="campoNomeFantasia"
                               promptText="Ex: Creme Rejuvenescedor"/>

                    <Label text="Tipo:"/>
                    <ComboBox fx:id="comboTipo" prefWidth="300"/>

                    <Label text="Observações:"/>
                    <TextArea fx:id="campoObservacoes" prefHeight="120"/>

                    <Label fx:id="mensagem" wrapText="true"/>
                </VBox>
            </HBox>

            <Separator/>

            <VBox spacing="8">
                <Label text="Ingredientes da Receita Selecionada:"
                       style="-fx-font-weight: bold;"/>

                <TableView fx:id="tabelaIngredientes" prefHeight="160">
                    <columns>
                        <TableColumn fx:id="colIngMP"      text="Matéria-Prima" prefWidth="220"/>
                        <TableColumn fx:id="colIngQtd"     text="Quantidade"    prefWidth="90"/>
                        <TableColumn fx:id="colIngUnidade" text="Unidade"       prefWidth="70"/>
                        <TableColumn fx:id="colIngObs"     text="Observação"    prefWidth="200"/>
                    </columns>
                </TableView>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="comboIngMP"      prefWidth="220" promptText="Matéria-prima..."/>
                    <TextField fx:id="campoIngQtd"    prefWidth="80"  promptText="Qtd."/>
                    <ComboBox fx:id="comboIngUnidade" prefWidth="70"/>
                    <TextField fx:id="campoIngObs"    prefWidth="160" promptText="Observação..."/>
                    <Button text="Adicionar" onAction="#adicionarIngrediente" styleClass="btn-salvar"/>
                    <Button text="Remover"   onAction="#removerIngrediente"   styleClass="btn-excluir"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="Fechar" onAction="#fechar" styleClass="btn-fechar"/>
        </HBox>
    </bottom>

</BorderPane>
