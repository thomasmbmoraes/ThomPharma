<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="thompharma.telas.LoteDialogController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Cadastro de Lote" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <VBox spacing="5">
            <Label text="Nome do Lote:"/>
            <TextField fx:id="campoNomeLote" prefWidth="180"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Validade:"/>
            <TextField fx:id="campoValidade" promptText="dd/mm/aaaa" prefWidth="110"/>
        </VBox>
    </HBox>

    <HBox spacing="10">
        <VBox spacing="5">
            <Label text="Quantidade:"/>
            <TextField fx:id="campoQuantidade" prefWidth="90"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Custo:"/>
            <TextField fx:id="campoCusto" prefWidth="90"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Densidade:"/>
            <TextField fx:id="campoDensidade" prefWidth="80"/>
        </VBox>
    </HBox>

    <HBox spacing="10">
        <VBox spacing="5">
            <Label text="Fator 1 (preço):"/>
            <TextField fx:id="campoFator" prefWidth="100"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Fator 2 (correção/marca):"/>
            <TextField fx:id="campoFator2" prefWidth="130"/>
        </VBox>
    </HBox>

    <HBox spacing="10">
        <VBox spacing="5">
            <Label text="End. Uso:"/>
            <TextField fx:id="campoEnderecoUso" prefWidth="140"/>
        </VBox>
        <VBox spacing="5">
            <Label text="End. Estoque:"/>
            <TextField fx:id="campoEnderecoEstoque" prefWidth="140"/>
        </VBox>
    </HBox>

    <Label text="Fornecedor:"/>
    <ComboBox fx:id="comboFornecedor" prefWidth="300"/>

    <Label fx:id="mensagem" style="-fx-text-fill: red;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Salvar" onAction="#salvar"/>
        <Button text="Cancelar" onAction="#cancelar"/>
    </HBox>

</VBox>
