<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.PedidosController"
            stylesheets="@thompharma.css">

    <top>
        <VBox styleClass="cabecalho">
            <Label text="Pedidos de Manipulação" styleClass="cabecalho-titulo"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>

            <HBox spacing="20">

                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Pedidos:"/>
                    <TextField fx:id="campoFiltro" promptText="Buscar por cliente..."/>
                    <ComboBox fx:id="comboFiltroStatus" prefWidth="200" onAction="#filtrar"/>
                    <TableView fx:id="tabelaPedidos" prefHeight="280">
                        <columns>
                            <TableColumn fx:id="colCliente"      text="Cliente"  prefWidth="160"/>
                            <TableColumn fx:id="colStatus"       text="Status"   prefWidth="100"/>
                            <TableColumn fx:id="colDataPedido"   text="Pedido"   prefWidth="90"/>
                            <TableColumn fx:id="colDataRetirada" text="Retirada" prefWidth="90"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button text="Novo"   onAction="#novo"    styleClass="btn-novo"/>
                        <Button text="Salvar" onAction="#salvar"  styleClass="btn-salvar"/>
                        <Button text="Excluir" onAction="#excluir" styleClass="btn-excluir"/>
                    </HBox>
                    <Label fx:id="mensagem" wrapText="true"/>
                </VBox>

                <ScrollPane fitToWidth="true" prefWidth="400">
                    <VBox spacing="8">
                        <padding><Insets top="2" right="8" bottom="2" left="2"/></padding>

                        <Label text="Cliente:"/>
                        <ComboBox fx:id="comboCliente" prefWidth="380"/>

                        <Label text="Prescritor (opcional):"/>
                        <ComboBox fx:id="comboPrescritor" prefWidth="380"/>

                        <Label text="Receita base (opcional):"/>
                        <ComboBox fx:id="comboReceita" prefWidth="380"/>

                        <HBox spacing="16">
                            <VBox spacing="4">
                                <Label text="Data do pedido:"/>
                                <DatePicker fx:id="dateDataPedido" prefWidth="170"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Data de retirada:"/>
                                <DatePicker fx:id="dateDataRetirada" prefWidth="170"/>
                            </VBox>
                        </HBox>

                        <Label text="Status:"/>
                        <ComboBox fx:id="comboStatus" prefWidth="200"/>

                        <Label text="Observações:"/>
                        <TextArea fx:id="campoObservacoes" prefHeight="80"/>
                    </VBox>
                </ScrollPane>
            </HBox>

            <Separator/>

            <VBox spacing="8">
                <Label text="Itens do Pedido:" style="-fx-font-weight: bold;"/>

                <TableView fx:id="tabelaItens" prefHeight="150">
                    <columns>
                        <TableColumn fx:id="colItemMP"       text="Matéria-Prima" prefWidth="220"/>
                        <TableColumn fx:id="colItemQtd"      text="Quantidade"    prefWidth="90"/>
                        <TableColumn fx:id="colItemUnidade"  text="Unidade"       prefWidth="70"/>
                        <TableColumn fx:id="colItemObs"      text="Observação"    prefWidth="200"/>
                    </columns>
                </TableView>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="comboItemMP"      prefWidth="220" promptText="Matéria-prima..."/>
                    <TextField fx:id="campoItemQtd"    prefWidth="80"  promptText="Qtd."/>
                    <ComboBox fx:id="comboItemUnidade" prefWidth="80"/>
                    <TextField fx:id="campoItemObs"    prefWidth="150" promptText="Observação..."/>
                    <Button text="Adicionar" onAction="#adicionarItem" styleClass="btn-salvar"/>
                    <Button text="Remover"   onAction="#removerItem"   styleClass="btn-excluir"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="Fechar" onAction="#fechar" styleClass="btn-fechar"/>
        </HBox>
    </bottom>

</BorderPane>
