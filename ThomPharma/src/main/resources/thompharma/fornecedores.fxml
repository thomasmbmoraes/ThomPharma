<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thompharma.telas.FornecedoresController"
            stylesheets="@thompharma.css">

    <top>
        <VBox styleClass="cabecalho">
            <Label text="Cadastro de Fornecedores" styleClass="cabecalho-titulo"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <VBox spacing="8" prefWidth="260">
                <Label text="Fornecedores:"/>
                <TextField fx:id="campoFiltro" promptText="Filtrar..."/>
                <TableView fx:id="tabelaFornecedores" prefHeight="420">
                    <columns>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="240"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" prefWidth="360">
                <fx:define><ToggleGroup fx:id="grupoDoc"/></fx:define>

                <Label text="Nome:"/>
                <TextField fx:id="campoNome"/>

                <Label text="Tipo de Documento:"/>
                <HBox spacing="14">
                    <RadioButton fx:id="radioCpf"   text="CPF"  toggleGroup="$grupoDoc"/>
                    <RadioButton fx:id="radioCnpj"  text="CNPJ" toggleGroup="$grupoDoc" selected="true"/>
                </HBox>

                <Label text="CNPJ / CPF:"/>
                <TextField fx:id="campoCnpj"/>

                <Label text="Contato:"/>
                <TextField fx:id="campoContato"/>

                <Label text="Telefone:"/>
                <TextField fx:id="campoTelefone"/>

                <Label text="Email:"/>
                <TextField fx:id="campoEmail"/>

                <HBox spacing="16">
                    <VBox spacing="5">
                        <Label text="Cidade:"/>
                        <TextField fx:id="campoCidade"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="UF:"/>
                        <TextField fx:id="campoUf" prefWidth="60"/>
                    </VBox>
                </HBox>

                <Label fx:id="mensagem" wrapText="true"/>

                <HBox spacing="10">
                    <Button text="Novo"    onAction="#novo"    styleClass="btn-novo"/>
                    <Button text="Salvar"  onAction="#salvar"  styleClass="btn-salvar"/>
                    <Button text="Excluir" onAction="#excluir" styleClass="btn-excluir"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="Fechar" onAction="#fechar" styleClass="btn-fechar"/>
        </HBox>
    </bottom>

</BorderPane>
